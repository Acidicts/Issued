<style>
  .design-detail {
    max-width: 980px;
    margin: 4rem auto 2rem;
    padding: 1.5rem;
    background: #ffffff;
    border-radius: 24px;
    box-shadow: 0 20px 45px rgba(15, 29, 52, 0.08);
  }

  .design-detail h1 {
    margin-top: 0;
    margin-bottom: 0.5rem;
    font-size: 3rem;
    letter-spacing: -0.03em;
  }

  .design-detail p.stat {
    margin: 0.5rem 0;
    color: #4f637f;
    line-height: 1.6;
  }

  .design-meta {
    display: grid;
    gap: 1rem;
    margin-bottom: 1.75rem;
  }

  .design-image-preview {
    display: grid;
    gap: 1rem;
    justify-content: center;
    align-items: start;
  }

  .design-preview {
    border: 1px solid #dce7f3;
    border-radius: 18px;
    padding: 1rem;
    background: #f8fbff;
    margin-bottom: 1rem;
    overflow: hidden;
    box-sizing: border-box;
  }

  .svg-preview {
    width: 200px;
    height: 200px;
    display: grid;
    place-items: center;
    margin: 0 auto;
    background: #ffffff;
    border-radius: 18px;
    border: 1px solid #e2e8f0;
  }

  .svg-preview svg {
    width: 100%;
    height: 100%;
  }

  .design-preview:not(.svg-preview) {
    width: 200px;
    height: 200px;
    padding: 0.5rem;
    margin: 0 auto 1rem;
  }

  .design-preview:not(.svg-preview) img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 14px;
  }

  .design-preview p {
    margin: 0;
    color: #66788a;
  }

  .design-actions {
    margin-top: 1.5rem;
  }

  .button-primary,
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.95rem 1.4rem;
    border-radius: 9999px;
    background: #3f71f3;
    color: #ffffff;
    border: 1px solid transparent;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 14px 28px rgba(63, 113, 243, 0.18);
    transition: transform 0.15s ease, box-shadow 0.15s ease, background-color 0.15s ease;
  }

  .button-primary:hover,
  .btn-primary:hover,
  .button-primary:focus,
  .btn-primary:focus {
    transform: translateY(-1px);
    box-shadow: 0 18px 32px rgba(63, 113, 243, 0.24);
    background: #3162d8;
  }

  .design-detail-container {
    display: flex;
    flex-direction: row;
    gap: 2.5rem;
  }

  @media (prefers-color-scheme: dark) {
    .design-detail {
      background: #1f2937;
      box-shadow: 0 20px 45px rgba(0, 0, 0, 0.18);
    }

    .design-detail p.stat,
    .design-preview p {
      color: #cbd5e1;
    }

    .design-preview {
      background: #111827;
      border-color: #374151;
    }
  }
</style>

<div class="design-detail design-detail-container">
  <div class="design-image-preview">
    <% if !@design.svg_empty? %>
      <div class="design-preview svg-preview">
          <%= svg_scaled(@design.svg_content) %>
      </div>
    <% end %>

    <% if @design.image.attached? %>
      <div class="design-preview">
        <%= image_tag @design.image, alt: "Additional image for #{@design.name}" %>
      </div>
    <% end %>
  </div>
  <div class="text-content">
    <h1><%= @design.name %></h1>
    <div class="design-meta">
      <p class="stat"><%= @design.description %></p>
      <p class="stat">Total time spent editing: <strong><%= @design.elapsed_time_formatted %></strong></p>
      <% if @design.hackatime_project.present? %>
        <p class="stat">Hackatime project: <strong><%= @design.hackatime_project %></strong></p>
        <p class="stat">Hackatime time: <strong><%= @design.hackatime_time_formatted %></strong></p>
      <% end %>
      <p class="stat">Updated: <strong><%= @design.updated_at.strftime("%B %d, %Y at %I:%M %p") %></strong></p>
    </div>
  </div>

  <div class="design-actions">
    <p><%= link_to "Edit design", edit_design_path(@design), class: "button-primary" %></p>
    <p><%= link_to "Edit in Editor", editor_design_path(@design), class: "button-primary" %></p>
  </div>
</div>
