<%= form_with model: [:admin, @user], local: true, class: "admin-user-form" do |f| %>
  <% if @user.errors.any? %>
    <div class="form-errors">
      <h2><%= pluralize(@user.errors.count, "error") %> prohibited this user from being saved:</h2>
      <ul>
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :name, class: "field-label" %>
    <%= f.text_field :name, class: "field-input", placeholder: "Full name" %>
  </div>

  <div class="field">
    <%= f.label :slack_id, class: "field-label" %>
    <%= f.text_field :slack_id, class: "field-input", placeholder: "U12345678" %>
  </div>

  <div class="field">
    <%= f.label :role, class: "field-label" %>
    <%= f.select :role, User.roles.keys.map { |r| [r.titleize, r] }, {}, class: "field-input" %>
  </div>

  <div class="field"> 
    <%= f.label :ysws_eligible, class: "field-label" do %>
      <%= f.check_box :ysws_eligible %> Eligible for YSWS
    <% end %>
  </div>

  <div class="actions">
    <%= f.submit @user.persisted? ? "Update User" : "Create User", class: "btn" %>
    <%= link_to "Back", admin_users_path, class: "btn btn-secondary" %>
  </div>
<% end %>

<style>
.admin-user-form {
  width: min(42rem, 95vw);
  margin: 1.5rem auto;
  background: #F2EAD3;
  border-radius: 4px;
  padding: 1.25rem;
}

.admin-user-form .field {
  display: flex;
  flex-direction: column;
  margin-bottom: 1rem;
}

.field-label {
  font-weight: 600;
  margin-bottom: 0.35rem;
}

.field-input {
  border: 1px solid #B7A878;
  border-radius: 4px;
  padding: 0.7rem 0.85rem;
  font-size: 1rem;
}

.field-input:focus {
  outline: 2px solid #1F6F78;
  border-color: #1F6F78;
}

.form-errors {
  border: 1px solid #D6402C;
  background: rgba(220, 38, 38, 0.08);
  border-radius: 4px;
  padding: 0.8rem;
  margin-bottom: 1rem;
}

.form-errors h2 {
  margin: 0 0 0.35rem 0;
  color: #991b1b;
}

.actions {
  display: flex;
  gap: 0.75rem;
  align-items: center;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.55rem 1rem;
  border: 1px solid #1F6F78;
  border-radius: 4px;
  background: #1F6F78;
  color: #fff;
  font-weight: 700;
  text-decoration: none;
}

.btn:hover {
  background: #1F6F78;
}

.btn-secondary {
  border-color: #6b7280;
  background: #D9CBA6;
  color: #241D16;
}

.btn-secondary:hover {
  background: #B7A878;
}

@media (prefers-color-scheme: dark) {
  .admin-user-form {
    background: rgba(26, 21, 16, 0.9);
    color: #e8dfd0;
    border: 1px solid #5a4f3e;
  }

  .field-input {
    background: #1a1510;
    color: #e8dfd0;
    border-color: #5a4f3e;
  }

  .field-input:focus {
    outline: 2px solid #1F6F78;
  }

  .btn-secondary {
    background: #3d3528;
    color: #e8dfd0;
  }
}
</style>