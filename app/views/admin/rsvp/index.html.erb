<style>
    h1 {
        font-family: 'Space Mono', 'Courier New', monospace;
        font-size: 2.8rem;
        margin-bottom: 1.5rem;
    }

    .rsvp-table {
        border-collapse: collapse;
        width: 90%;
        max-width: 1200px;
        margin: 0 auto;
    }

    .rsvp-table th,
    .rsvp-table td {
        border: 1px dashed #B7A878;
        padding: 1rem 1.1rem;
        vertical-align: middle;
    }

    .rsvp-table th {
        background-color: #F2EAD3;
        text-align: left;
        font-family: 'Space Mono', 'Courier New', monospace;
        font-size: 1.1rem;
        letter-spacing: 0.02em;
    }

    .rsvp-table tbody tr:hover {
        background-color: #E4D9BC;
    }

    .page-header {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 1rem;
        align-items: flex-start;
        margin-bottom: 1.25rem;
    }

    .page-header h1 {
        margin: 0;
        font-size: 2.8rem;
        font-family: 'Space Mono', 'Courier New', monospace;
    }

    .page-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        align-items: center;
        color: #475569;
        font-size: 1rem;
    }

    .import-card {
        background: #F2EAD3;
        border: 1.5px dashed #241D16;
        border-radius: 4px;
        padding: 1rem;
        margin: 0 auto 1.25rem;
        width: 90%;
        max-width: 1200px;
    }

    .import-form {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        align-items: center;
    }

    .import-form input[type="file"] {
        flex: 1;
        min-width: 240px;
    }

    .import-button {
        border: none;
        background: #0f766e;
        color: #ffffff;
        border-radius: 3px;
        padding: 0.55rem 0.95rem;
        font-weight: 600;
        cursor: pointer;
    }

    .import-help {
        margin-top: 0.6rem;
        color: #475569;
        font-size: 0.95rem;
    }

    .rsvp-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.55rem 0.95rem;
        border-radius: 3px;
        background: #1f7a8c;
        color: white;
        text-decoration: none;
        transition: background 0.2s ease;
    }

    .rsvp-link:hover {
        background: #175f70;
    }

    .action-buttons {
        display: flex;
        gap: 0.5rem;
        align-items: center;
    }

    .action-buttons form {
        margin: 0;
    }

    .action-buttons a,
    .action-buttons button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.55rem 0.9rem;
        text-decoration: none;
        border-radius: 3px;
        font-weight: 600;
        color: white;
        background-color: #ef4444;
        border: none;
        cursor: pointer;
        transition: background-color 0.2s ease;
    }

    .action-buttons a:hover,
    .action-buttons button:hover {
        background-color: #D6402C;
    }

    @media (max-width: 860px) {
        .rsvp-table {
            width: 100%;
        }

        .page-header {
            flex-direction: column;
            align-items: stretch;
        }

        .page-meta {
            justify-content: flex-start;
        }
    }

    @media (prefers-color-scheme: dark) {
        .rsvp-table th {
            background-color: #241D16;
            color: #f8fafc;
        }

        .rsvp-table td {
            background-color: #241D16;
            color: #D9CBA6;
        }
    }
</style>

<div class="page-header">
  <div>
    <h1>RSVPs</h1>
    <div class="page-meta">
      <span><%= @rsvps.count %> total RSVPs</span>
            <% rsvp_page_url = ENV["APP_URL"].present? ? "#{ENV["APP_URL"]}#{rsvp_path}" : rsvp_path %>
            <%= link_to "RSVP Page", rsvp_page_url, target: "_blank", rel: "noopener", class: "rsvp-link" %>
    </div>
  </div>
</div>

<div class="import-card">
    <%= form_with url: admin_rsvp_import_path, method: :post, local: true, html: { class: "import-form", multipart: true } do %>
        <%= file_field_tag :csv_file, accept: ".csv", required: true %>
        <%= submit_tag "Import CSV", class: "import-button" %>
    <% end %>
    <p class="import-help">CSV headers: <strong>slack_id</strong> (required), <strong>name</strong> (optional).</p>
</div>

<table class="rsvp-table">
  <thead>
    <tr>
      <th>Time</th>
      <th>Name</th>
      <th>Slack ID</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @rsvps.each do |rsvp| %>
      <tr>
        <td><%= rsvp.created_at %></td>
        <td><%= rsvp.user.name %></td>
        <td><%= rsvp.user.slack_id %></td>
        <td class="action-buttons">
          <%= button_to "Delete", admin_rsvp_delete_path(rsvp), method: :delete, class: "delete" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>