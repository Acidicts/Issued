<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Issued" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Issued">
    <meta name="mobile-web-app-capable" content="yes">
    <% if content_for?(:og_description) %>
      <meta name="description" content="<%= content_for(:og_description) %>">
    <% end %>
    <% if content_for?(:og_title) %>
      <meta property="og:title" content="<%= content_for(:og_title) %>">
    <% end %>
    <% if content_for?(:og_description) %>
      <meta property="og:description" content="<%= content_for(:og_description) %>">
    <% end %>
    <% if content_for?(:og_image) %>
      <% og_image_url = resolved_og_image_url(content_for(:og_image)) %>
      <% if og_image_url.present? %>
        <meta property="og:image" content="<%= og_image_url %>">
        <meta property="og:image:secure_url" content="<%= og_image_url %>">
        <meta property="og:image:width" content="1200">
        <meta property="og:image:height" content="630">
        <% if (og_image_type = og_image_mime_type(og_image_url)).present? %>
          <meta property="og:image:type" content="<%= og_image_type %>">
        <% end %>
        <meta name="twitter:image" content="<%= og_image_url %>">
      <% end %>
    <% end %>
    <% if content_for?(:twitter_card) %>
      <meta name="twitter:card" content="<%= content_for(:twitter_card) %>">
    <% end %>
    <% if content_for?(:og_author) %>
      <meta name="twitter:creator" content="<%= content_for(:og_author) %>">
    <% end %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">

    <style>
      body {
        background:
          radial-gradient(circle at 1px 1px, rgba(36, 29, 22, 0.05) 1px, transparent 1px) 0 0/14px 14px,
          #E4D9BC;
        color: #241D16;
        font-family: 'Space Mono', 'Courier New', monospace;
        font-size: 14px;
        line-height: 1.5;
        transition: background 0.3s ease, color 0.3s ease;
        margin: 0;
      }

      body.has-nav {
        padding-top: 7rem;
        margin-top: 5.5rem;
      }

      header {
        background: #F2EAD3;
        border-bottom: 1.5px dashed #B7A878;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        width: 100%;
        z-index: 50;
        overflow: hidden;
      }

      header::after {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        height: 3px;
        background: linear-gradient(90deg, rgba(183, 168, 120, 0.8), rgba(242, 234, 211, 0.2), rgba(183, 168, 120, 0.8));
        background-size: 200% 100%;
        animation: running-line 2.5s linear infinite;
        z-index: 51;
      }

      @keyframes running-line {
        0% { background-position: 0% 0%; }
        100% { background-position: -200% 0%; }
      }

      nav {
        width: 100%;
        margin: 0 auto;
        padding: 0.75rem 1rem;
        display: flex;
        justify-content: flex-start;
        align-items: center;
        gap: 1rem;
        left: 1rem;
      }

      .nav-link {
        font-family: 'Space Mono', 'Courier New', monospace;
        color: #241D16;
        text-decoration: none;
        font-weight: 700;
        padding: 0.5rem 0.75rem;
        border-radius: 2px;
        transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
      }

      .nav-link:hover,
      .nav-link:focus-visible {
        background: rgba(31, 111, 120, 0.15);
        color: #1F6F78;
      }

      @media (prefers-color-scheme: dark) {
        body {
          background:
            radial-gradient(circle at 1px 1px, rgba(232, 223, 208, 0.05) 1px, transparent 1px) 0 0/14px 14px,
            #1a1510;
          color: #e8dfd0;
        }

        header {
          background: #241d16;
          border-bottom-color: #5a4f3e;
        }

        header::after {
          background: linear-gradient(90deg, rgba(90, 79, 62, 0.8), rgba(36, 29, 22, 0.2), rgba(90, 79, 62, 0.8));
        }

        .nav-link {
          color: #e8dfd0;
        }

        .nav-link:hover,
        .nav-link:focus-visible {
          background: rgba(42, 138, 150, 0.2);
          color: #2a8a96;
        }

        .btn {
          border-color: rgba(232, 223, 208, 0.30);
          background: rgba(232, 223, 208, 0.1);
          color: #e8dfd0;
        }

        .btn:hover {
          background: rgba(232, 223, 208, 0.2);
        }
      }

      .btn {
        transition: background 0.14s ease, box-shadow 0.14s ease, color 0.14s ease;
      }

      /* signed-in tag header */
      .tag-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 50;
        background: #E4D9BC;
        border-bottom: 1.5px dashed #B7A878;
      }

      .tag-header .tag {
        max-width: 1180px;
        margin: 10px auto 0;
        background: #F2EAD3;
        border: 1.5px dashed #241D16;
        border-radius: 6px;
        padding: 14px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        position: relative;
      }

      .tag-header .tag::after {
        content: "";
        position: absolute;
        left: 20px;
        top: 50%;
        width: 14px;
        height: 14px;
        background: #E4D9BC;
        border: 1.5px dashed #241D16;
        border-radius: 50%;
        transform: translateY(-50%);
      }

      .tag-header .tag-left {
        margin-left: 40px;
        display: flex;
        align-items: baseline;
        gap: 10px;
      }

      .tag-header .wordmark {
        font-family: 'Archivo Black', 'Arial Black', sans-serif;
        font-size: 22px;
        letter-spacing: -0.5px;
      }

      .tag-header .wordmark .dot { color: #D6402C; }

      .tag-header .tagline {
        font-size: 10px;
        color: #4B4133;
        text-transform: uppercase;
        letter-spacing: 1.5px;
      }

      .tag-header .tag-right {
        display: flex;
        align-items: center;
        gap: 16px;
      }

      .tag-header .user-id {
        text-align: right;
        font-size: 10px;
        color: #4B4133;
      }

      .tag-header .user-id b {
        display: block;
        font-size: 13px;
        color: #241D16;
        font-weight: 700;
      }

      .tag-header .barcode {
        display: flex;
        align-items: flex-end;
        gap: 2px;
        height: 28px;
      }

      .tag-header .barcode span {
        display: block;
        background: #241D16;
      }

      .tag-header .threads-counter {
        background: #241D16;
        color: #E4D9BC;
        padding: 8px 14px;
        border-radius: 3px;
        text-align: center;
        min-width: 100px;
      }

      .tag-header .threads-counter .num {
        font-family: 'Archivo Black', 'Arial Black', sans-serif;
        font-size: 18px;
        color: #fff;
        display: block;
        line-height: 1;
      }

      .tag-header .threads-counter .label {
        font-size: 8px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #D9CBA6;
      }

      /* tabs nav */
      .tabs {
        display: flex;
        gap: 0;
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 20px;
        border-bottom: 1.5px solid #241D16;
      }

      .tab {
        font-family: 'Space Mono', 'Courier New', monospace;
        font-weight: 700;
        font-size: 11px;
        letter-spacing: 1px;
        text-transform: uppercase;
        background: none;
        border: none;
        padding: 10px 16px;
        cursor: pointer;
        color: #4B4133;
        text-decoration: none;
        position: relative;
        top: 1.5px;
        transition: color 0.15s ease;
      }

      .tab:hover { color: #241D16; }

      .tab.active {
        color: #241D16;
        border-bottom: 3px solid #D6402C;
      }

      .tab .pip {
        display: inline-block;
        background: #D6402C;
        color: #fff;
        font-size: 8px;
        padding: 1px 5px;
        border-radius: 8px;
        margin-left: 5px;
        vertical-align: 2px;
      }

      @media (prefers-color-scheme: dark) {
        .tag-header {
          background: #1a1510;
          border-bottom-color: #5a4f3e;
        }

        .tag-header .tag {
          background: #241d16;
          border-color: #5a4f3e;
        }

        .tag-header .tag::after {
          background: #1a1510;
          border-color: #5a4f3e;
        }

        .tag-header .tagline,
        .tag-header .user-id { color: #b8a890; }

        .tag-header .user-id b { color: #e8dfd0; }

        .tag-header .barcode span { background: #e8dfd0; }

        .tag-header .threads-counter {
          background: #e8dfd0;
          color: #241d16;
        }

        .tag-header .threads-counter .num { color: #241d16; }
        .tag-header .threads-counter .label { color: #5a4f3e; }

        .tabs { border-bottom-color: #5a4f3e; }
        .tab { color: #b8a890; }
        .tab:hover, .tab.active { color: #e8dfd0; }
      }
    </style>
  </head>

  <body class="<%= @nav != nil ? 'has-nav' : '' %>">
    <%= render "todo", show: true %>
    <% if signed_in? %>
      <header class="tag-header">
        <div class="tag">
          <div class="tag-left">
            <span class="wordmark">issued<span class="dot">.</span></span>
            <span class="tagline">design it in code · wear it for real</span>
          </div>
          <div class="tag-right">
            <div class="barcode" aria-hidden="true">
              <% ApplicationController::BARCODE_WIDTHS.each do |w| %>
                <span style="width:<%= w %>px; height:30px"></span>
              <% end %>
            </div>
            <div class="user-id">
              MAKER #<%= current_maker[:id] %>
              <b><%= current_maker[:name] %></b>
            </div>
            <div class="threads-counter">
              <span class="num"><%= format_threads(@threads || 0) %></span>
              <span class="label">threads</span>
            </div>
          </div>
        </div>
        <nav class="tabs">
          <%= link_to "Dashboard", dashboard_path, class: "tab #{"active" if @nav == "dashboard"}" %>
          <%= link_to "My Designs", designs_path, class: "tab #{"active" if @nav == "designs"}" %>
          <%= link_to "The Loom", shop_path, class: "tab #{"active" if @nav == "shop"}" %>
          <%= link_to notifications_path, class: "tab #{"active" if @nav == "notifications"}" do %>
            Notifications
            <% if unread_notification_count.positive? %>
              <span class="pip"><%= unread_notification_count %></span>
            <% end %>
          <% end %>
          <% if current_user.admin? %>
            <%= link_to "Admin", admin_overview_path, class: "tab" %>
          <% end %>
        </nav>
      </header>
    <% elsif @nav != nil %>
      <header>
        <nav>
          <div style="position: relative; width: 100%; display: flex; align-items: center; justify-content: space-between;">
            <div style="display: flex; gap: 1rem; align-items: center; left: 1rem;">
              <%= link_to "Home", root_path, class: "nav-link" %>
              <%= link_to "About", about_path, class: "nav-link" %>
              <%= link_to "FAQ", faq_path, class: "nav-link" %>
            </div>
            <div style="display: flex; gap: 1rem; align-items: center; right: 1rem; position: absolute; top: 0; bottom: 0; margin: auto;">
              <%= link_to "Login", login_path(redirect: request.fullpath), class: "nav-link" %>
            </div>
          </div>
        </nav>
      </header>
    <% end %>

    <div id="flash-container" aria-live="polite" aria-atomic="true">
      <% flash.each do |type, message| %>
        <div class="flash-message flash-<%= type %>"><%= message %></div>
      <% end %>
    </div>

    <%= yield %>

    <%= render "todo", show: true %>
  </body>
</html>
