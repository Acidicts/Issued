<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Issued" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Issued">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Workbench&display=swap" rel="stylesheet">

    <style>
      body {
        background: #f9fafb;
        color: #1f2937;
        transition: background 0.3s ease, color 0.3s ease;
        padding-top: 4.2rem;
        margin-top: 3rem;
      }

      header {
        background: rgba(255, 255, 255, 1);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid #fff;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        width: 100%;
        z-index: 50;
        overflow: hidden;
      }

      header::after {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        height: 3px;
        background: linear-gradient(90deg, rgba(255, 255, 255, 0.8), rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0.8));
        background-size: 200% 100%;
        animation: running-line 2.5s linear infinite;
        z-index: 51;
      }

      @keyframes running-line {
        0% { background-position: 0% 0%; }
        100% { background-position: -200% 0%; }
      }

      nav {
        width: 100%;
        margin: 0 auto;
        padding: 0.75rem 1rem;
        display: flex;
        justify-content: flex-start;
        align-items: center;
        gap: 1rem;
        left: 1rem;
      }

      .nav-link {
        font-family: Workbench, sans-serif;
        color: #111827;
        text-decoration: none;
        font-weight: 600;
        padding: 0.5rem 0.75rem;
        border-radius: 0.55rem;
        transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
      }

      .nav-link:hover,
      .nav-link:focus-visible {
        text-shadow: 0 0 0.75rem rgba(255, 255, 255, 1);
      }

      @media (prefers-color-scheme: dark) {
        body {
          background: #000000;
          color: #f3f4f6;
        }

        header {
          background: rgba(15, 23, 42, 0.86);
          border-bottom: rgba(255, 255, 255, 0.55);
        }

        .nav-link {
          color: #f3f4f6;
        }

        .nav-link:hover,
        .nav-link:focus-visible {
          background: rgba(147, 197, 253, 0.2);
          color: #bfdbfe;
        }

        .btn {
          border-color: rgba(255, 255, 255, 0.30);
          background: rgba(255, 255, 255, 0.1);
          color: #f3f4f6;
        }

        .btn:hover {
          background: rgba(255, 255, 255, 0.2);
          box-shadow: 0 10px 25px rgba(0, 0, 0, 0.35);
        }
      }

      .btn {
        transition: background 0.14s ease, box-shadow 0.14s ease, color 0.14s ease;
      }

      .dashboard-subnav {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.55rem 1.25rem;
        background: #f4f7fb;
        border-top: 1px solid #dfe7f2;
        border-bottom: 1px solid #dfe7f2;
        position: relative;
        z-index: 49;
      }

      .dashboard-subnav-parent {
        display: inline-flex;
        justify-content: space-between;
        width: 100%;
        align-items: center;
        gap: 0.75rem;
        padding: 0.55rem 1.25rem;
        background: #f4f7fb;
        border-top: 1px solid #dfe7f2;
        border-bottom: 1px solid #dfe7f2;
        position: relative;
        z-index: 49;
      }

      .dashboard-link {
        font-family: Workbench, sans-serif;
        font-size: 0.88rem;
        color: #1f2f45;
        padding: 0.48rem 0.75rem;
        border-radius: 0.5rem;
        text-decoration: none;
        transition: all 0.2s ease;
      }

      .dashboard-link:hover,
      .dashboard-link:focus-visible {
        background: #e9effa;
        color: #0f1850;
        transform: translateY(-1px);
      }

      .dashboard-link.active {
        background: #d4e0ff;
        color: #10379f;
        font-weight: 700;
      }

      @media (prefers-color-scheme: dark) {
        .dashboard-subnav {
          background: rgba(23, 35, 56, 0.95);
          border-top: 1px solid #1a2b45;
          border-bottom: 1px solid #1a2b45;
        }

        .dashboard-subnav-parent {
          background: rgba(23, 35, 56, 0.95);
          border-top: 1px solid #1a2b45;
          border-bottom: 1px solid #1a2b45;
        }

        .dashboard-link {
          color: #d6e7ff;
        }

        .dashboard-link:hover,
        .dashboard-link:focus-visible {
          background: rgba(70, 90, 134, 0.6);
          color: #ffffff;
        }

        .dashboard-link.active {
          background: rgba(50, 83, 146, 0.8);
          color: #e8f2ff;
        }
      }
    </style>
  </head>

  <body>
    <% if @nav != nil %>
      <header>
        <nav>
          <div style="position: relative; width: 100%; display: flex; align-items: center; justify-content: space-between;">
            <div style="display: flex; gap: 1rem; align-items: center; left: 1rem;">
              <%= link_to "Home", admin_overview_path, class: "nav-link" %>
              <%= link_to "Orders", admin_orders_path, class: "nav-link" %>
              <%= link_to "Products", admin_products_path, class: "nav-link" %>
              <%= link_to "Users", admin_users_path, class: "nav-link" %>
            </div>
            <div style="display: flex; gap: 1rem; align-items: center; right: 1rem; position: absolute; top: 0; bottom: 0; margin: auto;">
              <% if signed_in? %>
                <%= link_to "Dashboard", dashboard_path, class: "nav-link" %>
                <%= link_to "Logout", logout_path, method: :delete, class: "nav-link" %>
              <% else %>
                <%= link_to "Login", login_path(redirect: request.fullpath), class: "nav-link" %>
              <% end %>
            </div>
          </div>
        </nav>
      </header>
    <% end %>

    <div id="flash-container" aria-live="polite" aria-atomic="true">
      <% flash.each do |type, message| %>
        <div class="flash-message flash-<%= type %>"><%= message %></div>
      <% end %>
    </div>

    <%= yield %>
  </body>
</html>
