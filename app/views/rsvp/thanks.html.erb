<!DOCTYPE html>
<html>
	<head>
		<title>RSVP Confirmed | Issued</title>
		<meta name="viewport" content="width=device-width,initial-scale=1">
		<link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Workbench&display=swap" rel="stylesheet">

		<style>
			:root {
				--bg-a: #fff8db;
				--bg-b: #d4ffe8;
				--ink: #0f172a;
				--accent: #0a8f6a;
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				min-height: 100vh;
				display: grid;
				place-items: center;
				padding: 1.25rem;
				color: var(--ink);
				background: linear-gradient(145deg, var(--bg-a), var(--bg-b));
				font-family: "Space Grotesk", sans-serif;
			}

			.box {
				width: min(640px, 100%);
				border: 2px solid #0f172a;
				border-radius: 20px;
				background: rgba(255, 255, 255, 0.92);
				padding: 2rem;
				box-shadow: 9px 9px 0 #0f172a;
			}

			h1 {
				margin: 0;
				line-height: 1.1;
				font-family: workbench, monospace;
				font-size: clamp(1.5rem, 5vw, 2.8rem);
			}

			p {
				margin-top: 0.9rem;
				font-size: 1.05rem;
				line-height: 1.5;
			}

			.btns {
				margin-top: 1.25rem;
				display: flex;
				gap: 0.7rem;
				flex-wrap: wrap;
			}

			.btn {
				text-decoration: none;
				border-radius: 12px;
				border: 1px solid #0f172a;
				padding: 0.7rem 1rem;
				color: #0f172a;
				font-weight: 700;
				transition: transform 160ms ease;
			}

			.btn:hover {
				transform: translateY(-2px);
			}

			.btn.primary {
				color: #ffffff;
				background: var(--accent);
			}

			@media (max-width: 640px) {
				.box {
					padding: 1.25rem;
					box-shadow: 6px 6px 0 #0f172a;
				}

				.btn {
					width: 100%;
					text-align: center;
				}
			}
		</style>
	</head>

	<body>
		<main class="box">
			<h1>RSVP Confirmed</h1>
			<p>Your RSVP is saved. Thanks for supporting this YSWS.</p>

			<div class="btns">
				<%= link_to "Go Home", root_path, class: "btn primary" %>
			</div>
		</main>
	</body>
</html>
