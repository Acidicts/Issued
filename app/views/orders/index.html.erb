<div>
    <h1>Your Orders</h1>

    <% if @orders.any? %>
    <table class="orders-table">
        <thead>
        <tr>
            <th>Order ID</th>
            <th>Product</th>
            <th>Design</th>
            <th>Status</th>
            <th>Created At</th>
        </tr>
        </thead>
        <tbody>
        <% @orders.each do |order| %>
            <tr>
            <td><%= order.id %></td>
            <td><%= order.product&.name || "Unknown product" %></td>
            <td><%= order.design&.name || "Unknown design" %></td>
            <td><%= order.status %></td>
            <td><%= order.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            </tr>
        <% end %>
        </tbody>
    </table>
    <% else %>
        <p>You have no orders yet.</p>
    <% end %>
</div>