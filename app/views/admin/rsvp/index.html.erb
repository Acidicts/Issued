<style>
    h1 {
        font-family: Workbench, sans-serif;
        font-size: 2.8rem;
        margin-bottom: 1.5rem;
    }

    .rsvp-table {
        border-collapse: collapse;
        width: 90%;
        max-width: 1200px;
        margin: 0 auto;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.12);
    }

    .rsvp-table th,
    .rsvp-table td {
        border: 1px solid #e2e8f0;
        padding: 1rem 1.1rem;
    }

    .rsvp-table th {
        background-color: #f8fafc;
        text-align: left;
        font-family: Workbench, sans-serif;
        font-size: 1.1rem;
        letter-spacing: 0.02em;
    }

    .rsvp-table tbody tr:hover {
        background-color: #f1f5f9;
    }

    .action-buttons {
        display: flex;
        gap: 0.5rem;
        align-items: center;
    }

    .action-buttons a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.55rem 0.9rem;
        text-decoration: none;
        border-radius: 0.55rem;
        font-weight: 600;
        color: white;
        background-color: #ef4444;
        transition: background-color 0.2s ease, transform 0.2s ease;
    }

    .action-buttons a:hover {
        background-color: #dc2626;
        transform: translateY(-1px);
    }

    @media (prefers-color-scheme: dark) {
        .rsvp-table th {
            background-color: #1f2937;
            color: #f8fafc;
        }

        .rsvp-table td {
            background-color: #111827;
            color: #d1d5db;
        }

        .rsvp-table {
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);
        }
    }
</style>

<h1>RSVPs</h1>

<p><%= @rsvps.count %> total RSVPs</p>
<a href="<%= ENV['APP_URL']+rsvp_path %>" target="_blank">RSVP Page</a>

<table class="rsvp-table">
  <thead>
    <tr>
      <th>Time</th>
      <th>Name</th>
      <th>Slack ID</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @rsvps.each do |rsvp| %>
      <tr>
        <td><%= rsvp.created_at %></td>
        <td><%= rsvp.user.name %></td>
        <td><%= rsvp.user.slack_id %></td>
        <td class="action-buttons">
          <%= button_to "Delete", admin_rsvp_delete_path(rsvp), method: :delete, class: "delete" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>