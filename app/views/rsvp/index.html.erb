<%= content_for :title, "RSVP | Issued" %>
<%= content_for :og_title, "RSVP | Issued" %>
<%= content_for :og_description, "RSVP to Issued to design clothes with code and get them delivered!" %>
<%= content_for :og_image, "/og/rsvp.png" %>
<%= content_for :twitter_card, "summary_large_image" %>
<%= content_for :og_author, "Alex Hayes" %>

<% content_for :head do %>
  <style>
    .rsvp-page {
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 1.25rem;
    }

    body.has-nav .rsvp-page {
      min-height: calc(100vh - 6rem);
    }

    .rsvp-card {
      width: min(720px, 100%);
      padding: 2.2rem;
      border-radius: 4px;
      border: 1.5px dashed var(--ink, #241D16);
      background: var(--card, #F2EAD3);
      color: var(--ink, #241D16);
    }

    .rsvp-tag {
      display: inline-block;
      padding: 0.3rem 0.7rem;
      border-radius: 3px;
      border: 1px solid var(--ink, #241D16);
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .rsvp-title {
      margin: 0.5rem 0 0;
      font-family: var(--display, 'Archivo Black', 'Arial Black', sans-serif);
      font-size: clamp(2.1rem, 8.4vw, 4rem);
      font-weight: 700;
      line-height: 1.08;
    }

    .rsvp-subtitle {
      margin: 0.95rem 0 0;
      font-size: clamp(1rem, 2.6vw, 1.2rem);
      line-height: 1.5;
      max-width: 50ch;
      color: var(--ink-soft, #4B4133);
    }

    .rsvp-actions {
      margin-top: 1.6rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .rsvp-btn {
      appearance: none;
      border: 1.5px dashed var(--ink, #241D16);
      border-radius: 4px;
      padding: 0.72rem 1rem;
      text-decoration: none;
      font-family: var(--mono, 'Space Mono', monospace);
      font-weight: 700;
      font-size: 0.95rem;
      cursor: pointer;
      background: var(--card, #F2EAD3);
      color: var(--ink, #241D16);
      transition: background 160ms ease;
    }

    .rsvp-btn:hover {
      background: var(--paper, #E4D9BC);
    }

    .rsvp-btn.primary {
      background: var(--ink, #241D16);
      color: var(--paper, #E4D9BC);
      border-style: solid;
    }

    .rsvp-btn.primary:hover {
      background: var(--ink-soft, #4B4133);
    }

    .rsvp-btn.disabled {
      opacity: 0.5;
      cursor: not-allowed;
      pointer-events: none;
    }

    .rsvp-meta {
      margin-top: 1.25rem;
      font-size: 0.86rem;
      color: var(--ink-soft, #4B4133);
    }

    @media (max-width: 680px) {
      .rsvp-card { padding: 1.2rem; }
      .rsvp-actions { flex-direction: column; }
      .rsvp-btn { width: 100%; text-align: center; }
    }
  </style>
<% end %>

<div class="rsvp-page">
  <main class="rsvp-card" role="main">
    <% if @ended %>
      <span class="rsvp-tag">Closed</span>
      <h1 class="rsvp-title">Event Complete</h1>
      <p class="rsvp-subtitle">This chapter is wrapped. Thanks to everyone who participated and made Issued great.</p>
    <% elsif @running %>
      <span class="rsvp-tag">Closed</span>
      <h1 class="rsvp-title">Event Running</h1>
      <p class="rsvp-subtitle">RSVP is closed — go join the event now!</p>
    <% elsif @already_rsvped %>
      <span class="rsvp-tag">Confirmed</span>
      <h1 class="rsvp-title">You're In</h1>
      <p class="rsvp-subtitle">No double dipping!</p>
    <% elsif signed_in? %>
      <span class="rsvp-tag">Open</span>
      <h1 class="rsvp-title">RSVP to Issued</h1>
      <p class="rsvp-subtitle">One click away from supporting this ysws</p>
    <% else %>
      <span class="rsvp-tag">Open</span>
      <h1 class="rsvp-title">RSVP to Issued</h1>
      <p class="rsvp-subtitle">A few clicks from supporting this ysws</p>
    <% end %>

    <div class="rsvp-actions">
      <% if @can_rsvp %>
        <%= button_to "RSVP Now!", rsvp_submit_path, method: :post, class: "rsvp-btn primary" %>
      <% elsif !signed_in? && !@running && !@ended %>
        <%= link_to "RSVP Now!", login_path(redirect: rsvp_submit_after_login_path), class: "rsvp-btn primary" %>
      <% elsif @already_rsvped %>
        <%= link_to "Go To Home", dashboard_path, class: "rsvp-btn primary" %>
      <% else %>
        <%= link_to "Back Home", root_path, class: "rsvp-btn" %>
      <% end %>

      <%= link_to "FAQ", faq_path, class: "rsvp-btn" %>
      <%= link_to "About", about_path, class: "rsvp-btn" %>
    </div>

    <p class="rsvp-meta">Issued RSVP</p>
  </main>
</div>
