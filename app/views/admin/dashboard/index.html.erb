<% content_for :title, "Admin Dashboard" %>

<style>
	.admin-dashboard {
		--ink: #241D16;
		--line: #B7A878;
		--paper: #E4D9BC;
		--card: #F2EAD3;
		--muted: #B7A878;
		--accent: #1F6F78;
		--ok: #1F6F78;
		--warn: #B97F19;

		max-width: 1120px;
		margin: 1.5rem auto 2rem;
		padding: 1.25rem;
		border-radius: 4px;
		border: 1.5px dashed #241D16;
		background: #E4D9BC;
	}

	.admin-dashboard h1,
	.admin-dashboard h2 {
		font-family: 'Space Mono', 'Courier New', monospace;
		margin: 0;
	}

	.dashboard-header {
		margin-bottom: 1.1rem;
	}

	.dashboard-header h1 {
		font-size: clamp(2rem, 4vw, 3rem);
		color: var(--ink);
	}

	.dashboard-header p {
		margin: 0.35rem 0 0;
		color: var(--muted);
		font-size: 1rem;
		max-width: 65ch;
	}

	.summary-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.9rem;
	}

	.summary-card {
		background: #F2EAD3;
		border: 1.5px dashed #B7A878;
		border-radius: 4px;
		padding: 1rem;
	}

	.summary-card h2 {
		font-size: 1.3rem;
		color: var(--ink);
		margin-bottom: 0.75rem;
	}

	.summary-list {
		margin: 0;
		display: grid;
		gap: 0.55rem;
	}

	.summary-row {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		border-bottom: 1px dashed var(--line);
		padding-bottom: 0.25rem;
	}

	.summary-row dt {
		color: var(--muted);
		font-weight: 700;
	}

	.summary-row dd {
		margin: 0;
		font-weight: 700;
		color: var(--ink);
		font-size: 1.18rem;
	}

	.summary-row dd.ok {
		color: var(--ok);
	}

	.summary-row dd.warn {
		color: var(--warn);
	}

	.design-time {
		margin-top: 0.7rem;
		padding: 0.65rem 0.8rem;
		border-radius: 3px;
		background: #F2EAD3;
		border: 1.5px dashed #B7A878;
		color: var(--ink);
		font-size: 1.32rem;
		font-weight: 700;
		letter-spacing: 0.03em;
	}

	.design-caption {
		margin: 0.55rem 0 0;
		color: var(--muted);
		line-height: 1.4;
		font-size: 0.96rem;
	}

	.summary-link {
		display: inline-flex;
		margin-top: 0.85rem;
		text-decoration: none;
		color: #ffffff;
		background: var(--accent);
		border-radius: 3px;
		padding: 0.5rem 0.8rem;
		font-weight: 700;
		transition: background-color 0.2s ease;
	}

	.summary-link:hover,
	.summary-link:focus-visible {
		opacity: 0.85;
		background: #1e40af;
	}

	@media (max-width: 920px) {
		.summary-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (prefers-color-scheme: dark) {
		.admin-dashboard {
			--ink: #E4D9BC;
			--line: #B7A878;
			--paper: #241D16;
			--card: #241D16;
			--muted: #B7A878;
			--accent: #1F6F78;
			--ok: #1F6F78;
			--warn: #B97F19;

			background: #241D16;
		}

		.summary-row {
			border-bottom-color: #B7A878;
		}

		.design-time {
			background: #241D16;
			border: 1.5px dashed #B7A878;
		}
	}
</style>

<main class="admin-dashboard">
	<div class="dashboard-header">
		<h1>Admin Dashboard</h1>
		<p>Summary of Site Info</p>
	</div>

	<section class="summary-grid" aria-label="Admin summary metrics">
		<article class="summary-card">
			<h2>Orders</h2>
			<dl class="summary-list">
				<div class="summary-row">
					<dt>Total</dt>
					<dd><%= @orders_total %></dd>
				</div>
				<div class="summary-row">
					<dt>Fulfilled</dt>
					<dd class="ok"><%= @orders_fulfilled %></dd>
				</div>
				<div class="summary-row">
					<dt>Pending</dt>
					<dd class="warn"><%= @orders_pending %></dd>
				</div>
			</dl>
			<%= link_to "Manage Orders", admin_orders_path, class: "summary-link" %>
		</article>

		<article class="summary-card">
			<h2>Users</h2>
			<dl class="summary-list">
				<div class="summary-row">
					<dt>Total</dt>
					<dd><%= @users_total %></dd>
				</div>
				<div class="summary-row">
					<dt>RSVPs</dt>
					<dd><%= @users_rsvps %></dd>
				</div>
			</dl>
			<%= link_to "Manage Users", admin_users_path, class: "summary-link" %>
		</article>

		<article class="summary-card">
			<h2>Designs</h2>
			<p class="design-caption">Highest tracked time</p>
			<div class="design-time"><%= @highest_time_formatted %></div>
			<p class="design-caption">
				<% if @highest_time_design.present? %>
					<strong><%= @highest_time_design.name %></strong> currently has the highest total editing time.
				<% else %>
					No designs have tracked time yet.
				<% end %>
			</p>
			<%= link_to "View Designs", designs_path, class: "summary-link" %>
		</article>
	</section>
</main>
