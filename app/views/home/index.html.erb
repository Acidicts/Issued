<style>
  body {
    font-family: 'Space Mono', 'Courier New', monospace;
    margin: 0;
    padding: 0;
    background:
      radial-gradient(circle at 1px 1px, rgba(36, 29, 22, 0.05) 1px, transparent 1px) 0 0/14px 14px,
      #E4D9BC;
    color: #241D16;
  }

  #container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;
    padding: 5rem 2rem 3rem;
    gap: 1.75rem;
    margin: 5rem 5rem;
  }

  #title {
    font-family: 'Archivo Black', 'Arial Black', sans-serif;
    font-size: clamp(5rem, 10vw, 12rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
    margin: 0;
  }

  #descriptors {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 0.75rem;
  }

  #descriptor0,
  #descriptor1 {
    font-size: clamp(1rem, 2.4vw, 1.5rem);
    font-weight: 400;
    margin: 0;
  }

  #btns {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .btn {
    border: 1.5px dashed #241D16;
    background: #F2EAD3;
    color: #241D16;
    font-size: 1rem;
    font-weight: 600;
    border-radius: 4px;
    padding: 0.75rem 0.6rem;
    cursor: pointer;
    min-width: 6rem;
    transition: background 0.14s ease;
    text-decoration: none;
    text-align: center;
  }

  .btn:hover {
    background: #E4D9BC;
  }

  .btn:focus-visible {
    outline: 2px solid #1F6F78;
    outline-offset: 2px;
  }

  @media (max-width: 750px) {
    #container {
      align-items: stretch;
      padding: 2rem 1rem;
    }

    #title {
      font-size: clamp(4rem, 14vw, 7rem);
    }

    #btns {
      justify-content: center;
    }

    .btn {
      width: 100%;
      max-width: 260px;
      text-align: center;
    }
  }

  @media (prefers-color-scheme: dark) {
    body {
      background:
        radial-gradient(circle at 1px 1px, rgba(232, 223, 208, 0.05) 1px, transparent 1px) 0 0/14px 14px,
        #1a1510;
      color: #e8dfd0;
    }

    .btn {
      border-color: #5a4f3e;
      background: #241D16;
      color: #e8dfd0;
    }

    .btn:hover {
      background: #3d3528;
    }

    .btn:focus-visible {
      outline-color: #2a8a96;
    }
  }
</style>


<div id="container">
    <div class="workbench" id="title">Issued</div>
    
    <br id="break">

    <div id="container2">
        <div id="descriptors">
            <div class="offside" id="descriptor0">Make Designs With Code</div>
            <div class="offside" id="descriptor1">Get Custom Apparel</div>
        </div>
        <div id="btns">
            <% if !signed_in? && (ENV["RUNNING"] == "true" && ENV["RSVP_OPEN"] == "false") || params["demo"]=="true" %>
              <%= link_to "Start", login_path(redirect: dashboard_path), class: "btn" %>
              <% if params["demo"] == "true" %>
                <%= link_to "RSVP", rsvp_path, class: "btn disabled", disabled: true %>
              <% end %>
            <% elsif (ENV["RUNNING"] == "true" && ENV["RSVP_OPEN"]) == "false" || params["demo"]=="true" %>
              <%= link_to "Start", dashboard_path, class: "btn" %>
            <% else %>
              <%= link_to "RSVP", rsvp_path, class: "btn disabled", disabled: true %>
            <% end %>
            <%= link_to "About", about_path, class: "btn" %>
            <%= link_to "FAQ", faq_path, class: "btn" %>
        </div>
    </div>
</div>