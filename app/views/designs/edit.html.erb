<style>
    .design-edit-page {
        --ink: #241D16;
        --ink-soft: #4B4133;
        --muted: #5b6980;
        --surface: #F2EAD3;
        --line: #B7A878;
        --stamp-red: #D6402C;
        --thread-teal: #1F6F78;
        min-height: calc(100vh - 2rem);
        padding: clamp(1rem, 2.4vw, 2.75rem);
        background:
            radial-gradient(circle at 1px 1px, rgba(36,29,22,0.05) 1px, transparent 1px) 0 0/14px 14px,
            #E4D9BC;
        font-family: 'Space Mono', 'Courier New', monospace;
        color: var(--ink);
    }

    .design-edit-page .design-edit-card {
        width: min(760px, 100%);
        margin-inline: auto;
        padding: clamp(1.35rem, 3vw, 2.6rem);
        border-radius: 4px;
        border: 1.5px dashed var(--ink);
        background: var(--surface);
    }

    .design-edit-page .design-edit-kicker {
        margin: 0;
        font-size: 0.75rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        font-weight: 800;
        color: var(--ink-soft);
    }

    .design-edit-page h1 {
        margin: 0.6rem 0 0;
        font-size: clamp(2rem, 4vw, 2.8rem);
        line-height: 1.1;
        letter-spacing: -0.035em;
        color: var(--ink);
    }

    .design-edit-page .design-edit-intro {
        margin: 0.9rem 0 1.9rem;
        max-width: 54ch;
        font-size: 1rem;
        line-height: 1.5;
        color: var(--ink-soft);
    }

    @media (max-width: 640px) {
        .design-edit-page {
            min-height: auto;
            padding: 0.8rem;
        }
        .design-edit-page .design-edit-card {
            border-radius: 4px;
            padding: 1.1rem;
        }
    }
</style>

<div class="design-edit-page">
    <section class="design-edit-card">
        <h1>Edit Design</h1>
        <p class="design-edit-intro">Tune details, sync tracked time, and keep your submission polished.</p>
        <%= render "form" %>
    </section>
</div>
