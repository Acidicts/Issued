<%= content_for :title, "RSVP | Issued" %>
<%= content_for :og_title, "RSVP | Issued" %>
<%= content_for :og_description, "RSVP to Issued to design clothes with code and get them delivered!" %>
<%= content_for :og_image, "RSVP.png" %>
<%= content_for :twitter_card, "summary_large_image" %>
<%= content_for :og_author, "Alex Hayes" %>

<% content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Major+Mono+Display&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Workbench&display=swap" rel="stylesheet">

  <style>
    :root {
      --bg-1: #fdf6e3;
      --bg-2: #c4f5ff;
      --ink: #111111;
      --panel: rgba(255, 255, 255, 0.86);
      --border: #111111;
      --accent: #1f7a8c;
      --accent-2: #d1495b;
    }

    * {
      box-sizing: border-box;
    }

    .page-shell {
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 1.25rem;
      background:
        radial-gradient(circle at 15% 20%, rgba(209, 73, 91, 0.22), transparent 38%),
        radial-gradient(circle at 88% 12%, rgba(31, 122, 140, 0.28), transparent 40%),
        linear-gradient(135deg, var(--bg-1), var(--bg-2));
    }

    body.has-nav .page-shell {
      min-height: calc(100vh - 6rem);
    }

    .grain {
      position: fixed;
      inset: 3rem 0 0;
      pointer-events: none;
      background-image: radial-gradient(rgba(0, 0, 0, 0.08) 0.5px, transparent 0.5px);
      background-size: 5px 5px;
      opacity: 0.3;
    }

    .card {
      width: min(720px, 100%);
      padding: 2.2rem;
      border-radius: 24px;
      border: 2px solid var(--border);
      background: var(--panel);
      color: var(--ink);
      box-shadow: 10px 10px 0 #111111;
      position: relative;
      overflow: hidden;
      animation: rise-in 420ms ease-out;
    }

    .tag {
      display: inline-block;
      padding: 0.3rem 0.7rem;
      border-radius: 999px;
      border: 1px solid var(--border);
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      background: #fff;
    }

    .hero {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.45rem;
    }

    .title {
      margin: 0;
      position: relative;
      display: inline-block;
      font-family: workbench, monospace;
      font-size: clamp(2.1rem, 8.4vw, 4rem);
      font-weight: 700;
      line-height: 1.08;
      max-width: 100%;
      word-break: break-word;
      color: var(--ink);
      transition: color 200ms ease, transform 200ms ease;
    }

    .title::after {
      content: attr(data-text);
      position: absolute;
      inset: 0;
      white-space: inherit;
      font-family: monospace;
      font-size: 2rem;
      color: var(--ink);
      opacity: 0;
      transform: translateY(6px) scale(0.985);
      transition: opacity 220ms ease, transform 220ms ease;
      pointer-events: none;
      z-index: 1;
    }

    .title:hover {
      color: transparent;
      transform: translateY(-1px);
    }

    .title:hover::after {
      opacity: 1;
      transform: translateY(0) scale(1);
    }

    .subtitle {
      margin: 0.95rem 0 0;
      font-size: clamp(1rem, 2.6vw, 1.2rem);
      line-height: 1.5;
      max-width: 50ch;
      color: var(--ink);
    }

    .actions {
      margin-top: 1.6rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .actions .btn,
    .actions button.btn {
      appearance: none;
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 0.72rem 1rem;
      text-decoration: none;
      color: var(--ink);
      background: #ffffff;
      font-weight: 700;
      font-size: 0.95rem;
      cursor: pointer;
      transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
    }

    .actions .btn.primary,
    .actions button.btn.primary {
      background: linear-gradient(120deg, var(--accent), #48a9a6);
      color: #ffffff;
    }

    .actions .btn:hover,
    .actions button.btn:hover {
      transform: translate(-2px, -2px);
      box-shadow: 5px 5px 0 rgba(17, 17, 17, 0.9);
    }

    .actions .btn.disabled {
      opacity: 0.5;
      cursor: not-allowed;
      pointer-events: none;
    }

    .meta {
      margin-top: 1.25rem;
      font-size: 0.86rem;
      opacity: 0.8;
      color: var(--ink);
    }

    @media (prefers-color-scheme: dark) {
      .card,
      .tag,
      .subtitle,
      .meta {
        color: var(--ink);
      }

      .actions .btn,
      .actions button.btn {
        border-color: var(--border);
        background: #ffffff;
        color: var(--ink);
      }

      .actions .btn.primary,
      .actions button.btn.primary {
        background: linear-gradient(120deg, var(--accent), #48a9a6);
        color: #ffffff;
      }
    }

    @media (max-width: 680px) {
      .card {
        padding: 1.2rem;
        border-radius: 18px;
        box-shadow: 6px 6px 0 #111111;
      }

      .title {
        margin-top: 0.8rem;
        line-height: 1.02;
      }

      .actions {
        flex-direction: column;
      }

      .actions .btn,
      .actions button.btn {
        width: 100%;
        text-align: center;
      }
    }

    @keyframes rise-in {
      from {
        opacity: 0;
        transform: translateY(14px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>
<% end %>

<div class="page-shell">
  <div class="grain" aria-hidden="true"></div>

  <main class="card" role="main">
    <% if @ended %>
      <div class="hero">
        <span class="tag">Closed</span>
        <h1 class="title" data-text="Event Complete">Event Complete</h1>
      </div>
      <p class="subtitle">This chapter is wrapped. Thanks to everyone, who participated and made Issued great.</p>
    <% elsif @running %>
      <div class="hero">
        <span class="tag">Closed</span>
        <h1 class="title" data-text="Event Running">Event Running</h1>
      </div>
      <p class="subtitle">RSVP is closed go join the event now!</p>
    <% elsif @already_rsvped %>
      <div class="hero">
        <span class="tag">Confirmed</span>
        <h1 class="title" data-text="You're In">You're In</h1>
      </div>
      <p class="subtitle">No double dipping!</p>
    <% elsif signed_in? %>
      <div class="hero">
        <span class="tag">Open</span>
        <h1 class="title" data-text="Reserve Your Spot">RSVP to Issued</h1>
      </div>
      <p class="subtitle">One click to support this ysws</p>
    <% else %>
      <div class="hero">
        <span class="tag">Open</span>
        <h1 class="title" data-text="RSVP Now">RSVP to Issued</h1>
      </div>
      <p class="subtitle">A few clicks from supporting this ysws</p>
    <% end %>

    <div class="actions">
      <% if @can_rsvp %>
        <%= button_to "RSVP Now!", rsvp_submit_path, method: :post, class: "btn primary" %>
      <% elsif !signed_in? && !@running && !@ended %>
        <%= link_to "RSVP Now!", login_path(redirect: rsvp_submit_after_login_path), class: "btn primary" %>
      <% elsif @already_rsvped %>
        <%= link_to "Go To Home", dashboard_path, class: "btn primary" %>
      <% else %>
        <%= link_to "Back Home", root_path, class: "btn" %>
      <% end %>

      <%= link_to "FAQ", faq_path, class: "btn" %>
      <%= link_to "About", about_path, class: "btn" %>
    </div>

    <p class="meta">Issued RSVP</p>
  </main>
</div>
