<%= content_for :title, "RSVP Confirmed | Issued" %>

<% content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Space+Mono&display=swap" rel="stylesheet">

  <style>
    :root {
      --bg-a: #fff8db;
      --bg-b: #d4ffe8;
      --ink: #0f172a;
      --accent: #0a8f6a;
    }

    * {
      box-sizing: border-box;
    }

    .page-shell {
      min-height: calc(100vh - 6rem);
      display: grid;
      place-items: center;
      padding: 1.25rem;
      background: #E4D9BC;
      background-image: radial-gradient(rgba(0, 0, 0, 0.08) 0.5px, transparent 0.5px);
      background-size: 5px 5px;
      font-family: 'Space Mono', 'Courier New', monospace;
      color: var(--ink);
    }

    .box {
      width: min(640px, 100%);
      border: 2px solid #0f172a;
      border-radius: 4px;
      background: #F2EAD3;
      padding: 2rem;
    }

    h1 {
      margin: 0;
      line-height: 1.1;
      font-family: 'Space Mono', 'Courier New', monospace;
      font-size: clamp(1.5rem, 5vw, 2.8rem);
    }

    p {
      margin-top: 0.9rem;
      font-size: 1.05rem;
      line-height: 1.5;
    }

    .btns {
      margin-top: 1.25rem;
      display: flex;
      gap: 0.7rem;
      flex-wrap: wrap;
    }

    .btn {
      text-decoration: none;
      border-radius: 4px;
      border: 1.5px solid #241D16;
      padding: 0.7rem 1rem;
      color: #241D16;
      font-weight: 700;
      background: #F2EAD3;
      transition: background 160ms ease;
    }

    .btn:hover {
      background: #E4D9BC;
    }

    .btn.primary {
      color: #ffffff;
      background: #241D16;
    }

    @media (max-width: 640px) {
      .box {
        padding: 1.25rem;
      }

      .btn {
        width: 100%;
        text-align: center;
      }
    }
  </style>
<% end %>

<div class="page-shell">
  <main class="box">
    <h1>RSVP Confirmed</h1>
    <p>Your RSVP is saved. Thanks for supporting this YSWS.</p>

    <div class="btns">
      <%= link_to "Go Home", root_path, class: "btn primary" %>
    </div>
  </main>
</div>